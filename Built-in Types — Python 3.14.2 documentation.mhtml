><span class=3D"n">array</span><span class=3D"p">(</span><span class=3D"s1"=
>'l'</span><span class=3D"p">,</span> <span class=3D"p">[</span><span class=
=3D"mi">1</span><span class=3D"p">,</span><span class=3D"mi">2</span><span =
class=3D"p">,</span><span class=3D"mi">3</span><span class=3D"p">])</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"n">x</span> <span cla=
ss=3D"o">=3D</span> <span class=3D"nb">memoryview</span><span class=3D"p">(=
</span><span class=3D"n">a</span><span class=3D"p">)</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"n">x</span><span clas=
s=3D"o">.</span><span class=3D"n">format</span>
<span class=3D"go">'l'</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"n">x</span><span clas=
s=3D"o">.</span><span class=3D"n">itemsize</span>
