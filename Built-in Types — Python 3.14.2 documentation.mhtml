=3D"pre">=3D</span></span><span class=3D"default_value"><span class=3D"pre"=
>None</span></span></em>, <em class=3D"sig-param"><span class=3D"n"><span c=
lass=3D"pre">maxsplit</span></span><span class=3D"o"><span class=3D"pre">=
=3D</span></span><span class=3D"default_value"><span class=3D"pre">-1</span=
></span></em><span class=3D"sig-paren">)</span><a class=3D"headerlink" href=
=3D"https://docs.python.org/3/library/stdtypes.html#bytes.split" title=3D"L=
ink to this definition">=C2=B6</a></dt>
<dt class=3D"sig sig-object py" id=3D"bytearray.split">
<span class=3D"sig-prename descclassname"><span class=3D"pre">bytearray.</s=
pan></span><span class=3D"sig-name descname"><span class=3D"pre">split</spa=
n></span><span class=3D"sig-paren">(</span><em class=3D"sig-param"><span cl=
ass=3D"n"><span class=3D"pre">sep</span></span><span class=3D"o"><span clas=
s=3D"pre">=3D</span></span><span class=3D"default_value"><span class=3D"pre=
">None</span></span></em>, <em class=3D"sig-param"><span class=3D"n"><span =
class=3D"pre">maxsplit</span></span><span class=3D"o"><span class=3D"pre">=
=3D</span></span><span class=3D"default_value"><span class=3D"pre">-1</span=
></span></em><span class=3D"sig-paren">)</span><a class=3D"headerlink" href=
=3D"https://docs.python.org/3/library/stdtypes.html#bytearray.split" title=
=3D"Link to this definition">=C2=B6</a></dt>
<dd><p>Split the binary sequence into subsequences of the same type, using =
<em>sep</em>
as the delimiter string. If <em>maxsplit</em> is given and non-negative, at=
 most
<em>maxsplit</em> splits are done (thus, the list will have at most <code c=
lass=3D"docutils literal notranslate"><span class=3D"pre">maxsplit+1</span>=
</code>
elements).  If <em>maxsplit</em> is not specified or is <code class=3D"docu=
tils literal notranslate"><span class=3D"pre">-1</span></code>, then there =
is no
limit on the number of splits (all possible splits are made).</p>
<p>If <em>sep</em> is given, consecutive delimiters are not grouped togethe=
r and are
deemed to delimit empty subsequences (for example, <code class=3D"docutils =
literal notranslate"><span class=3D"pre">b'1,,2'.split(b',')</span></code>
returns <code class=3D"docutils literal notranslate"><span class=3D"pre">[b=
'1',</span> <span class=3D"pre">b'',</span> <span class=3D"pre">b'2']</span=
></code>).  The <em>sep</em> argument may consist of a
multibyte sequence as a single delimiter. Splitting an empty sequence with
a specified separator returns <code class=3D"docutils literal notranslate">=
<span class=3D"pre">[b'']</span></code> or <code class=3D"docutils literal =
notranslate"><span class=3D"pre">[bytearray(b'')]</span></code> depending
on the type of object being split.  The <em>sep</em> argument may be any
<a class=3D"reference internal" href=3D"https://docs.python.org/3/glossary.=
html#term-bytes-like-object"><span class=3D"xref std std-term">bytes-like o=
bject</span></a>.</p>
<p>For example:</p>
<div class=3D"highlight-python3 notranslate"><div class=3D"highlight" style=
=3D"position: relative;"><button class=3D"copybutton" type=3D"button" title=
=3D"Copy to clipboard">Copy</button><pre><span></span><span class=3D"gp">&g=
t;&gt;&gt; </span><span class=3D"sa">b</span><span class=3D"s1">'1,2,3'</sp=
an><span class=3D"o">.</span><span class=3D"n">split</span><span class=3D"p=
">(</span><span class=3D"sa">b</span><span class=3D"s1">','</span><span cla=
ss=3D"p">)</span>
<span class=3D"go">[b'1', b'2', b'3']</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"sa">b</span><span cla=
ss=3D"s1">'1,2,3'</span><span class=3D"o">.</span><span class=3D"n">split</=
span><span class=3D"p">(</span><span class=3D"sa">b</span><span class=3D"s1=
">','</span><span class=3D"p">,</span> <span class=3D"n">maxsplit</span><sp=
an class=3D"o">=3D</span><span class=3D"mi">1</span><span class=3D"p">)</sp=
an>
<span class=3D"go">[b'1', b'2,3']</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"sa">b</span><span cla=
ss=3D"s1">'1,2,,3,'</span><span class=3D"o">.</span><span class=3D"n">split=
</span><span class=3D"p">(</span><span class=3D"sa">b</span><span class=3D"=
s1">','</span><span class=3D"p">)</span>
<span class=3D"go">[b'1', b'2', b'', b'3', b'']</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"sa">b</span><span cla=
ss=3D"s1">'1&lt;&gt;2&lt;&gt;3&lt;4'</span><span class=3D"o">.</span><span =
class=3D"n">split</span><span class=3D"p">(</span><span class=3D"sa">b</spa=
n><span class=3D"s1">'&lt;&gt;'</span><span class=3D"p">)</span>
<span class=3D"go">[b'1', b'2', b'3&lt;4']</span>
</pre></div>
</div>
<p>If <em>sep</em> is not specified or is <code class=3D"docutils literal n=
otranslate"><span class=3D"pre">None</span></code>, a different splitting a=
lgorithm
is applied: runs of consecutive ASCII whitespace are regarded as a single
separator, and the result will contain no empty strings at the start or
end if the sequence has leading or trailing whitespace.  Consequently,
splitting an empty sequence or a sequence consisting solely of ASCII
whitespace without a specified separator returns <code class=3D"docutils li=
teral notranslate"><span class=3D"pre">[]</span></code>.</p>
<p>For example:</p>
<div class=3D"highlight-python3 notranslate"><div class=3D"highlight" style=
=3D"position: relative;"><button class=3D"copybutton" type=3D"button" title=
=3D"Copy to clipboard">Copy</button><pre><span></span><span class=3D"gp">&g=
t;&gt;&gt; </span><span class=3D"sa">b</span><span class=3D"s1">'1 2 3'</sp=
an><span class=3D"o">.</span><span class=3D"n">split</span><span class=3D"p=
">()</span>
<span class=3D"go">[b'1', b'2', b'3']</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"sa">b</span><span cla=
ss=3D"s1">'1 2 3'</span><span class=3D"o">.</span><span class=3D"n">split</=
span><span class=3D"p">(</span><span class=3D"n">maxsplit</span><span class=
=3D"o">=3D</span><span class=3D"mi">1</span><span class=3D"p">)</span>
<span class=3D"go">[b'1', b'2 3']</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"sa">b</span><span cla=
ss=3D"s1">'   1   2   3   '</span><span class=3D"o">.</span><span class=3D"=
n">split</span><span class=3D"p">()</span>
<span class=3D"go">[b'1', b'2', b'3']</span>
</pre></div>
</div>
</dd></dl>

