pan><span class=3D"n">isnumeric</span><span class=3D"p">()</span>  <span cl=
ass=3D"c1"># Arabic-indic digit zero to nine</span>
<span class=3D"go">True</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"s1">'=E2=85=95'</span=
><span class=3D"o">.</span><span class=3D"n">isnumeric</span><span class=3D=
"p">()</span>  <span class=3D"c1"># Vulgar fraction one fifth</span>
<span class=3D"go">True</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"s1">'=C2=B2'</span><s=
pan class=3D"o">.</span><span class=3D"n">isdecimal</span><span class=3D"p"=
>(),</span> <span class=3D"s1">'=C2=B2'</span><span class=3D"o">.</span><sp=
an class=3D"n">isdigit</span><span class=3D"p">(),</span>  <span class=3D"s=
1">'=C2=B2'</span><span class=3D"o">.</span><span class=3D"n">isnumeric</sp=
an><span class=3D"p">()</span>
<span class=3D"go">(False, True, True)</span>
