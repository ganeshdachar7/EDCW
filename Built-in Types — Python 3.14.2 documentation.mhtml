<span class=3D"p">([</span><span class=3D"mi">1</span><span class=3D"p">],<=
/span> <span class=3D"nb">int</span> <span class=3D"o">|</span> <span class=
=3D"nb">list</span><span class=3D"p">[</span><span class=3D"nb">int</span><=
