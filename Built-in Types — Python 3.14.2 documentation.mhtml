</dd></dl>

<dl class=3D"py method">
<dt class=3D"sig sig-object py" id=3D"str.maketrans">
<em class=3D"property"><span class=3D"k"><span class=3D"pre">static</span><=
/span><span class=3D"w"> </span></em><span class=3D"sig-prename descclassna=
me"><span class=3D"pre">str.</span></span><span class=3D"sig-name descname"=
