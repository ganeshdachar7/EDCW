<div class=3D"highlight-python3 notranslate"><div class=3D"highlight" style=
=3D"position: relative;"><button class=3D"copybutton" type=3D"button" title=
=3D"Copy to clipboard">Copy</button><pre><span></span><span class=3D"gp">&g=
t;&gt;&gt; </span><span class=3D"sa">b</span><span class=3D"s1">'   spaciou=
s   '</span><span class=3D"o">.</span><span class=3D"n">strip</span><span c=
lass=3D"p">()</span>
