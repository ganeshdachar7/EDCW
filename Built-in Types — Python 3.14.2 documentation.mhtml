thon.org/3/reference/compound_stmts.html#def"><code class=3D"xref std std-k=
eyword docutils literal notranslate"><span class=3D"pre">def</span></code><=
/a> and <a class=3D"reference internal" href=3D"https://docs.python.org/3/r=
eference/compound_stmts.html#class"><code class=3D"xref std std-keyword doc=
utils literal notranslate"><span class=3D"pre">class</span></code></a>.</p>
<p>Example:</p>
<div class=3D"highlight-python3 notranslate"><div class=3D"highlight" style=
=3D"position: relative;"><button class=3D"copybutton" type=3D"button" title=
=3D"Copy to clipboard">Copy</button><pre><span></span><span class=3D"gp">&g=
t;&gt;&gt; </span><span class=3D"kn">from</span><span class=3D"w"> </span><=
span class=3D"nn">keyword</span><span class=3D"w"> </span><span class=3D"kn=
">import</span> <span class=3D"n">iskeyword</span>

<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"s1">'hello'</span><sp=
an class=3D"o">.</span><span class=3D"n">isidentifier</span><span class=3D"=
p">(),</span> <span class=3D"n">iskeyword</span><span class=3D"p">(</span><=
span class=3D"s1">'hello'</span><span class=3D"p">)</span>
<span class=3D"go">(True, False)</span>
<span class=3D"gp">&gt;&gt;&gt; </span><span class=3D"s1">'def'</span><span=
 class=3D"o">.</span><span class=3D"n">isidentifier</span><span class=3D"p"=
>(),</span> <span class=3D"n">iskeyword</span><span class=3D"p">(</span><sp=
an class=3D"s1">'def'</span><span class=3D"p">)</span>
<span class=3D"go">(True, True)</span>
</pre></div>
</div>
</dd></dl>

